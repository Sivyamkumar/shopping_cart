<div class="row checkout">
    <div class="col-md-3"></div>
    <div class="col-md-6 main">
        <h1>Checkout</h1>
        <h4>Your Total: ${{total}}</h4>
        <div id="charge-error" class="alert alert-danger {{#if noError}}invisible{{/if}}">
            {{errMsg}}
        </div>
        <form action="/checkout" method="post" id="checkout-form">
            <div class="main-title">
                <label for="name">Name</label>
                <input type="text" class="form-control" id="name" name="name" required>
            </div>
            <div class="checkout">
                <label for="address">Address</label>
                <input type="text" class="form-control" id="address" name="address" required>
            </div>
            <div class="checkout">
                <label for="card-element">Credit or debit card</label>
                <div id="card-element" class="form-control" style="height: 2.4em; padding-top: 0.7em;">
                  <!-- A Stripe Element will be inserted here. -->
                </div>
                <!-- Used to display form errors. -->
                <div id="card-errors" role="alert" class="text-danger"></div>
            </div>
            <button class="btn btn-raised btn-success main button-submit" type="submit">Buy</button>
        </form>
    </div>
</div>

<script src="https://js.stripe.com/v3/"></script>
<script>
    var stripePublishableKey = '{{publishableKey}}';
</script>
<script src="/javascripts/checkout.js"></script>
